# GitHub OAuth App — github.com/settings/developers → "New OAuth App".
# Authorization callback URL:  https://<your-domain>/api/auth/callback/github
#   (also add http://localhost:3001/api/auth/callback/github while developing)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Session-encryption secret. Generate one with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=

# Upstream repository the pull request targets. The PR is opened from the signed-in user's OWN fork,
# authored by them — point this at a throwaway repo while testing.
GITHUB_SUBMIT_REPO=SmolDapp/tokenAssets
GITHUB_SUBMIT_BASE=main
